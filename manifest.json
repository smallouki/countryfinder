{
  "manifest_version": 3,
  "name": "Show Country",
  "version": "1.2.8",
  "description": "Resolves the page host to an IP, shows country via geolocation, and displays a bottom flag overlay (IP and country on hover).",
  "permissions": ["storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/bottom_bar.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://dns.quad9.net/*",
    "https://doh.opendns.com/*",
    "https://dns.adguard-dns.com/*",
    "https://cloudflare-dns.com/*",
    "https://1.1.1.1/*",
    "https://ipinfo.io/*",
    "https://ipwho.is/*",
    "https://ipapi.co/*",
    "https://get.geojs.io/*",
    "http://ip-api.com/*",
    "https://flagcdn.com/*"
  ]
}
